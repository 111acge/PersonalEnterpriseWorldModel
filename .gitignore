# ===== 本地数据（运行时生成，可重建）=====
data/
.vector/

# ===== PyInstaller 打包产物 =====
build/
dist/
*.spec
!build.spec
*.manifest
*.spec.bak

# ===== 环境变量与敏感文件 =====
.env
*.pem
*.key
credentials.json

# ===== 配置备份与导出文件（含敏感信息）=====
config-backup-*/
*config-export*.json
world-model-config-*.json

# ===== 用户笔记内容（隐私，不入库；保留 .gitkeep 占位）=====
00-Inbox/**/*.md
10-Theory/**/*.md
20-Ontology/**/*.md
30-Instances/**/*.md
40-Skills/**/*.md
!.gitkeep

# ===== Python 编译与缓存 =====
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so
*.egg-info/
*.egg
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ===== 测试与类型检查缓存 =====
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# ===== IDE 编辑器 =====
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ===== 操作系统 =====
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ===== 日志 =====
*.log
pewm/pipeline.log
logs/

# ===== 前端依赖与覆盖率 =====
node_modules/
coverage.json

# ===== 虚拟环境 =====
.venv/
venv/
ENV/
env/

# ===== Jupyter =====
.ipynb_checkpoints/

# ===== 备注 =====
# bge-model/ 是内置的语义向量模型（约 92MB），打包时必须保留，不要加入 gitignore
# 如果你用 git lfs 管理大文件，建议单独配置 lfs 追踪 bge-model/pytorch_model.bin
